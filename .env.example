# Require the persistent production graph. Use "networkx" only for offline demos.
SWAPIQ_GRAPH_BACKEND=neo4j

# Local: bolt://localhost:7687
# Aura:  neo4j+s://<database-id>.databases.neo4j.io
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=replace-with-a-secret
NEO4J_DATABASE=neo4j
NEO4J_CONNECTION_TIMEOUT=10

# Use true only to bootstrap the deterministic demo catalog automatically.
# For hosted environments, run neo4j_loader.py once and leave this false.
NEO4J_AUTO_SYNC=false

# Optional. The deterministic fallback keeps ranking and listing fixes available.
ANTHROPIC_API_KEY=
